{
  "name": "@equip-track/source",
  "version": "0.0.18-beta.32",
  "license": "MIT",
  "scripts": {
    "fullstack": "nx run-many --parallel --target=serve --projects=backend,frontend",
    "frontend:serve:dev": "node scripts/write-runtime-config.js https://dev-api.equip-track.com && nx s frontend",
    "validate:translations": "node scripts/validate-translation-keys.js",
    "generate:sam": "node scripts/generate-sam-template.js",
    "deploy:sam": "node scripts/deploy-sam-api.js",
    "e2e:local:stack:up": "docker compose -f docker-compose.e2e.yml up -d --wait localstack",
    "e2e:local:stack:down": "docker compose -f docker-compose.e2e.yml down",
    "e2e:local:stack:reset": "docker compose -f docker-compose.e2e.yml down -v",
    "e2e:local:setup": "node scripts/setup-local-e2e.js",
    "e2e:local:prepare": "npm run e2e:local:stack:up && npm run e2e:local:setup",
    "e2e:local:install-browsers": "npx playwright install chromium",
    "backend:serve:e2e-local": "env STAGE=local AWS_REGION=us-east-1 AWS_ENDPOINT_URL=http://localhost:4566 AWS_ENDPOINT_URL_DYNAMODB=http://localhost:4566 AWS_ENDPOINT_URL_S3=http://localhost:4566 AWS_ENDPOINT_URL_SECRETSMANAGER=http://localhost:4566 AWS_ACCESS_KEY_ID=test AWS_SECRET_ACCESS_KEY=test E2E_AUTH_ENABLED=true E2E_AUTH_SECRET=e2e-local-secret BACKEND_PORT=3000 LOCAL_HTTP_SERVER=true bash -c \"nx run backend:build:development && node dist/apps/backend/main.js\"",
    "frontend:serve:e2e-local": "node scripts/write-runtime-config.js http://localhost:3000 && nx run frontend:serve",
    "e2e:local:test": "npm run e2e:local:prepare && npm run e2e:local:install-browsers && PLAYWRIGHT_HTML_OPEN=never E2E_SKIP_LOCAL_E2E_ENSURE=true npx nx run frontend-e2e:e2e-local-core",
    "e2e:deployed:test": "npm run e2e:local:install-browsers && PLAYWRIGHT_HTML_OPEN=never npx nx run frontend-e2e:e2e-deployed-core",
    "precommit": "nx affected -t lint,test --uncommitted --nxBail --exclude=frontend-e2e,backend-e2e && npm run validate:translations",
    "prepare": "husky"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "21.2.6",
    "@angular/cdk": "21.2.4",
    "@angular/common": "21.2.6",
    "@angular/compiler": "21.2.6",
    "@angular/core": "21.2.6",
    "@angular/forms": "21.2.6",
    "@angular/material": "21.2.4",
    "@angular/platform-browser": "21.2.6",
    "@angular/platform-browser-dynamic": "21.2.6",
    "@angular/router": "21.2.6",
    "@aws-sdk/client-dynamodb": "^3.828.0",
    "@aws-sdk/client-s3": "^3.848.0",
    "@aws-sdk/client-secrets-manager": "^3.848.0",
    "@aws-sdk/lib-dynamodb": "^3.828.0",
    "@aws-sdk/s3-request-presigner": "^3.858.0",
    "@ng-select/ng-select": "^21.5.2",
    "@ngneat/until-destroy": "^10.0.0",
    "@ngrx/signals": "^21.1.0",
    "@ngx-translate/core": "^16.0.4",
    "@ngx-translate/http-loader": "^16.0.1",
    "@types/jsonwebtoken": "^9.0.10",
    "axios": "^1.6.0",
    "google-auth-library": "^10.1.0",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^3.0.0",
    "jspdf-autotable-rtl": "^1.0.2",
    "ngx-mat-multi-sort": "^21.0.1",
    "ngxtension": "^5.0.0",
    "rxjs": "~7.8.0",
    "signature_pad": "^5.0.9",
    "zone.js": "0.16.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "21.2.3",
    "@angular-devkit/core": "21.2.3",
    "@angular-devkit/schematics": "21.2.3",
    "@angular/cli": "21.2.3",
    "@angular/compiler-cli": "21.2.6",
    "@angular/language-service": "21.2.6",
    "@eslint/js": "^9.8.0",
    "@nx/angular": "22.6.1",
    "@nx/devkit": "22.6.1",
    "@nx/esbuild": "22.6.1",
    "@nx/eslint": "22.6.1",
    "@nx/eslint-plugin": "22.6.1",
    "@nx/jest": "22.6.1",
    "@nx/js": "22.6.1",
    "@nx/node": "22.6.1",
    "@nx/playwright": "22.6.1",
    "@nx/web": "22.6.1",
    "@nx/workspace": "22.6.1",
    "@playwright/test": "^1.55.1",
    "@schematics/angular": "21.2.3",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.19",
    "@types/aws-lambda": "^8.10.150",
    "@types/cors": "^2.8.17",
    "@types/express": "4.17.25",
    "@types/jest": "30.0.0",
    "@types/node": "18.16.9",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/utils": "^8.33.1",
    "angular-eslint": "21.3.1",
    "esbuild": "^0.27.4",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-playwright": "^1.6.2",
    "husky": "^9.1.7",
    "jest": "30.3.0",
    "jest-environment-jsdom": "30.3.0",
    "jest-environment-node": "30.3.0",
    "jest-preset-angular": "16.1.1",
    "jest-util": "30.3.0",
    "nx": "22.6.1",
    "prettier": "^2.6.2",
    "ts-jest": "29.4.6",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.33.1"
  },
  "overrides": {
    "picomatch": "4.0.4",
    "serialize-javascript": "7.0.5",
    "undici": "7.24.6"
  }
}

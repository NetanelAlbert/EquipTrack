# Copy to .env.preview on the preview host (do not commit secrets).
PREVIEW_SEED_PASSWORD=replace-with-shared-team-secret
E2E_AUTH_SECRET=e2e-local-secret

# Local laptop: default binds 127.0.0.1:8080 (no path prefix).
# Shared host with path-based public URL: bind each PR to a unique loopback port (see docs/pr-preview-environments.md).
# PREVIEW_BIND=127.0.0.1:30123

# Optional — path-based preview on a single hostname (e.g. https://pr-preview.example.com/123/).
# Set PREVIEW_PUBLIC_ORIGIN to the public origin (no path) and PREVIEW_PATH_SEGMENT to the PR number.
# PREVIEW_PUBLIC_ORIGIN=https://pr-preview.example.com
# PREVIEW_PATH_SEGMENT=123
